
/flower_framework_testing/flower_framework_testing/krutyanjay_testing/flower_venv/

# Do not commit raw client image data.
/flower-fl/client/data/**

# Keep data directories discoverable in fresh clones.
!/flower-fl/client/data/
!/flower-fl/client/data/.gitkeep
!/flower-fl/client/data/**/
!/flower-fl/client/data/**/.gitkeep

# Ignore dataset archives (cause zip archives are more than 100MB)
*.zip

# Python cache and bytecode
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Logs and temporary files
*.log
temp*/

# IDE/editor settings
.vscode/
.idea/
.DS_Store

# Flower checkpoints or other model artifacts
*.pth
*.pt
*.npz
*.npy
